{
  "name": "thegraybot-evals",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A tiny, reproducible demo: scoring a 'Gray Cat' persona chatbot with Evalite (local) and self-hosted Langfuse (dashboard). For a YouTube video about LLM evals.",
  "scripts": {
    "eval": "evalite watch",
    "eval:watch": "evalite watch",
    "eval:ci": "evalite",
    "try": "tsx evals/try-agent.ts",
    "seed:langfuse": "tsx evals/seed-langfuse.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "1.0.40",
    "@langfuse/client": "5.4.1",
    "@langfuse/otel": "5.4.1",
    "@langfuse/tracing": "5.4.1",
    "@opentelemetry/sdk-node": "0.207.0",
    "ai": "5.0.203",
    "dotenv": "17.2.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "evalite": "0.19.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ]
  }
}
