# ─── Copy this file to `.env` and fill in real values. `.env` is gitignored. ───

# --- Moonshot Kimi (powers BOTH the agent and the LLM-as-judge scorers) ---
# Get a key at https://platform.moonshot.ai/ . The agent uses the OpenAI-compatible
# Chat Completions endpoint, so any Moonshot key works.
MOONSHOT_API_KEY=sk-your-moonshot-key

# International platform base URL (includes /v1). Use api.moonshot.cn/v1 for the China platform.
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Model ids. Defaults shown; confirm what's enabled on your account with:
#   curl https://api.moonshot.ai/v1/models -H "Authorization: Bearer $MOONSHOT_API_KEY"
MOONSHOT_MODEL=kimi-k2-0905-preview        # capable default for the agent
MOONSHOT_ALT_MODEL=moonshot-v1-8k          # cheaper/smaller model used in ONE seeding run
MOONSHOT_JUDGE_MODEL=kimi-k2.5             # fixed model for the LLM judges

# --- No-key smoke test ---
# Set to 1 to run the WHOLE pipeline (Evalite + Langfuse wiring) with canned,
# deterministic replies and a heuristic judge — no API key, no token spend.
# Leave UNSET for real Kimi calls.
# GRAYCAT_MOCK=1

# --- Langfuse (self-hosted by default; see README Act 2) ---
# NOTE: it's LANGFUSE_BASE_URL (with the underscore), not LANGFUSE_BASEURL.
# These DEMO keys match the headless bootstrap in langfuse/docker-compose.yml, so they
# work out-of-the-box against the local stack. (If you create keys manually in the UI
# instead, paste those here.) DEMO ONLY — never reuse for anything real.
LANGFUSE_PUBLIC_KEY=pk-lf-graycat-demo-public
LANGFUSE_SECRET_KEY=sk-lf-graycat-demo-secret
LANGFUSE_BASE_URL=http://localhost:3000

# Langfuse Cloud fallback (swap the two lines above for one of these + cloud keys):
#   LANGFUSE_BASE_URL=https://us.cloud.langfuse.com   # US region
#   LANGFUSE_BASE_URL=https://cloud.langfuse.com      # EU region

# Number of seeding runs (more runs = longer trend line). Default 5.
# RUNS=5
